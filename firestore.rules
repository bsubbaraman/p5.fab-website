rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // True iff `display` (mixed-case) names a registry doc owned by uid whose canonical
    // display matches exactly. The registry is keyed by the lowercase, so look it up there.
    // Defined INSIDE this match block so $(database) is in scope for exists()/get().
    function ownsUsername(display, uid) {
      let key = display.lower();
      return display is string
        && display.size() >= 3 && display.size() <= 30
        && display.matches('^[a-zA-Z0-9_]+$')
        && exists(/databases/$(database)/documents/usernames/$(key))
        && get(/databases/$(database)/documents/usernames/$(key)).data.uid == uid
        && get(/databases/$(database)/documents/usernames/$(key)).data.display == display;
    }

    match /users/{userId} {
      allow read: if true;
      // username is bound to the registry: it may only be set/changed to a name whose
      // usernames/{lowercase} doc this user owns. This is what prevents impersonation.
      allow create: if isSignedInAs(userId)
        && ownsUsername(request.resource.data.username, userId);
      allow update: if isSignedInAs(userId)
        && (request.resource.data.get('username', '') == resource.data.get('username', '')
          || ownsUsername(request.resource.data.username, userId));
      allow delete: if isSignedInAs(userId);
    }

    // Username registry: one doc per name, keyed by the LOWERCASE username (uniqueness),
    // with the original-case `display` preserved. Claimed directly by the owner; atomic
    // create + the create-only rule make collisions impossible, and display.lower() == key
    // makes the displayed casing unspoofable.
    match /usernames/{key} {
      allow read: if true;
      allow create: if isAuthenticated()
        && request.resource.data.uid == request.auth.uid
        && request.resource.data.keys().hasOnly(['uid', 'display', 'created'])
        && key.size() >= 3 && key.size() <= 30
        && key.matches('^[a-z0-9_]+$')
        && request.resource.data.display is string
        && request.resource.data.display.matches('^[a-zA-Z0-9_]+$')
        && request.resource.data.display.lower() == key;
      allow update: if false;                            // immutable: no repoint / takeover
      allow delete: if isSignedInAs(resource.data.uid);  // owner may release / roll back
    }

    match /posts/{postID} {
      // Anyone can read
      allow read: if true;
      // Must be signed in to post, must be the author, and fields must be valid
      allow create: if isAuthenticated()
        && request.auth.uid == request.resource.data.authorUID
        && validPost(request.resource.data);
      // The author can update their own post (but cannot change authorship).
      // Anyone else may ONLY toggle their own like — no other cross-user writes.
      // (Forks are no longer recorded on the parent post; they're derived from each
      // fork's own parentSketch link, so there is no addingAFork() path anymore.)
      allow update: if (isAuthenticated() && togglingOwnLike())
        || (request.auth.uid == request.resource.data.authorUID
          && request.auth.uid == resource.data.authorUID
          && validPostUpdate(request.resource.data));
      allow delete: if request.auth.uid == resource.data.authorUID;
    }

    // allPosts is no longer used - locked down
    match /posts/allPosts {
      allow read, write: if false;
    }

  }


  function isAuthenticated() {
    return request.auth != null;
  }

  function isSignedInAs(uid) {
    return isAuthenticated() && request.auth.uid == uid;
  }

  function validPost(data) {
    return data.name is string && data.name.size() <= 200
      && data.info is string && data.info.size() <= 10000
      && data.code is string && data.code.size() <= 100000
      && data.hasFabricated in ['yes', 'no']
      && data.isFork is bool
      && data.favorites == 0
      && data.numForks == 0;
  }

  function validPostUpdate(data) {
    return data.name is string && data.name.size() <= 200
      && data.info is string && data.info.size() <= 10000
      && data.code is string && data.code.size() <= 100000;
  }

  // A signed-in user may only move a post's like count by toggling their OWN
  // entry in the favoritedBy map: +1 iff their uid goes absent->present, -1 iff
  // present->absent, with no other favoritedBy key or post field changed. This makes
  // one-like-per-user enforceable in the rule (the client toggle is not a boundary).
  function togglingOwnLike() {
    let uid = request.auth.uid;
    let before = resource.data;
    let after = request.resource.data;
    let bFav = ('favoritedBy' in before) ? before.favoritedBy : {};
    let aFav = ('favoritedBy' in after) ? after.favoritedBy : {};
    return after.diff(before).affectedKeys().hasOnly(['favorites', 'favoritedBy'])
      && aFav.diff(bFav).affectedKeys().hasOnly([uid])
      && (
        (after.favorites == before.favorites + 1 && !(uid in bFav) && (uid in aFav))
        || (after.favorites == before.favorites - 1 && (uid in bFav) && !(uid in aFav))
      );
  }

}
